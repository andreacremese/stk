// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/go .
{
	"name": "Go",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/go:2-1.26-trixie",
	"features": {
		"ghcr.io/devcontainers/features/git-lfs:1": {},
		"ghcr.io/devcontainers/features/python:1": {
			"version": "3.12"
		}
	},
	"containerEnv": {
		"AGENT_STACK_DB_PATH": "/home/vscode/.config/agent-stack/stacks.db"
	},
	"mounts": [
		"source=stk-go-mod-cache,target=/go/pkg/mod,type=volume",
		"source=stk-go-build-cache,target=/home/vscode/.cache/go-build,type=volume",
		"source=stk-agent-stack-data,target=/home/vscode/.config/agent-stack,type=volume"
	],
	"postCreateCommand": "sudo apt-get update && sudo apt-get install -y sqlite3 && go mod download && go install github.com/golangci/golangci-lint/cmd/golangci-lint@v2.11.3 && go install github.com/securego/gosec/v2/cmd/gosec@latest && python3 -m pip install --user pre-commit semgrep ggshield && pre-commit install",
	"customizations": {
		"vscode": {
			"extensions": [
				"golang.Go",
				"GitHub.vscode-github-actions",
				"redhat.vscode-yaml",
				"alexcvzz.vscode-sqlite"
			],
			"settings": {
				"editor.formatOnSave": true,
				"editor.codeActionsOnSave": {
					"source.organizeImports": "explicit"
				},
				"go.useLanguageServer": true,
				"go.formatTool": "goimports",
				"go.lintTool": "golangci-lint",
				"go.testFlags": [
					"-race",
					"-cover"
				],
				"go.toolsManagement.checkForUpdates": "local",
				"gopls": {
					"formatting.gofumpt": false,
					"ui.semanticTokens": true
				}
			}
		}
	}

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "go version",

	// Configure tool-specific properties.
	// "customizations": {},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
